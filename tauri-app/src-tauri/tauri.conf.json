{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HT Logistic Agent",
  "version": "0.1.6",
  "identifier": "com.local.ht-logistic-agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "HT Logistic Agent",
        "width": 1440,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": false,
        "backgroundColor": "#f1f1f3"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:8000 http://127.0.0.1:8000"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": [],
    "resources": {
      "../../python-sidecar/ht-sidecar*": "./",
      "pi-runtime.7z": "./pi-runtime.7z"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "installerHooks": "installer-hooks.nsh"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/jameszeng222/ht-logistic-workspace-v2/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDOTdGOEI4NkY2MTA0OTMKUldTVEJHRnZ1UGlYclBHRUltVkVobkN1WkNxRHZYcEk4cGVTOE9VU29UcytYcE4xdXZEdWx3Z0EK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
