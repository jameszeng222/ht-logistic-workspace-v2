# ============ Python sidecar ============
python-sidecar/__pycache__/
python-sidecar/**/*.pyc
python-sidecar/.venv/
python-sidecar/venv/
python-sidecar/build/
python-sidecar/dist/
python-sidecar/*.egg-info/
# PyInstaller 打包产物（构建时生成，不提交）
python-sidecar/ht-sidecar
python-sidecar/ht-sidecar.exe
# pi-runtime（构建时下载便携 Node + pi 包，不提交）
pi-runtime/
# Build script compresses pi-runtime to pi-runtime.7z so tauri.conf.json
# can bundle it as a single-file resource (avoids NSIS MAX_PATH 260 limit
# with @mistralai's deeply nested files). Never commit this.
tauri-app/src-tauri/pi-runtime.7z
# Old build script copied pi-runtime here as loose files (pre-7z approach).
# Kept for safety in case old script is run; never commit.
tauri-app/src-tauri/pi-runtime/

# Tauri / Node
tauri-app/node_modules/
tauri-app/dist/
tauri-app/src-tauri/target/

# Local UI verification artifacts
.playwright-cli/
output/

# IDE
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# 本地环境变量
.env
.env.local
